# =========================================================
# FIREBASE WEB APP (público; Firebase Console > Project settings > Your apps)
# =========================================================
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_ENABLE_APPLE_AUTH=false

# =========================================================
# FIREBASE ADMIN SDK (secreto; service account)
# Firebase Console > Project settings > Service accounts
# =========================================================
FIREBASE_PROJECT_ID=
# Opcional: se vazio, o servidor reutiliza NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET.
FIREBASE_STORAGE_BUCKET=
FIREBASE_CLIENT_EMAIL=
# Copie a chave inteira entre aspas. Preserve os caracteres \\n.
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\\nSUA_CHAVE\\n-----END PRIVATE KEY-----\\n"

# =========================================================
# APLICAÇÃO
# =========================================================
BOOTSTRAP_ADMIN_EMAIL=miguelmickelberg@gmail.com
BOOTSTRAP_ADMIN_NAME=Miguel Mickelberg
MAX_ACTIVE_ADMINS=2
SESSION_DAYS=5
APP_URL=http://localhost:3000
# Use uma sequência aleatória longa. Exemplo: openssl rand -base64 48
APP_SECRET=

# Opcional: usado pelo importador de calendário e metadados
FIFA_SCHEDULE_SOURCE_URL=https://www.fifa.com/en/tournaments/mens/worldcup/canadamexicousa2026/scores-fixtures

# =========================================================
# DADOS EXTERNOS DA COPA (opcional)
# Sem esta chave, a classificação é calculada pelos resultados do Firestore.
# Com a chave, o módulo consulta a API-Football (league=1, season=2026).
# =========================================================
API_FOOTBALL_KEY=

# Segredo usado pelo Google Cloud Scheduler para chamar o endpoint de placar ao vivo.
# Gere uma sequência aleatória com ao menos 32 caracteres.
LIVE_SCORE_CRON_SECRET=
